{
  "framework": "vite",
  "installCommand": "cd frontend && pnpm install --frozen-lockfile",
  "buildCommand": "cd frontend && node scripts/ensure-production-env.mjs && pnpm build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
