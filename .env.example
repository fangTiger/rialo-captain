# Rialo-Captain backend
DATABASE_URL=sqlite+aiosqlite:///./rialo.db
JWT_SECRET=change-me-in-prod-32-chars-min
JWT_COOKIE_NAME=rialo_session
JWT_TTL_HOURS=720
# Cookie 安全：生产 HTTPS 设 true，本地 HTTP 必须 false
COOKIE_SECURE=false
# 仅 dev 使用：开启 /auth/dev-login 绕过 Google OAuth
DEV_LOGIN_ENABLED=true
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
RIALO_MODE=mock
ADMIN_TOKEN=local-dev-admin-token
OPENSKY_BASE_URL=https://opensky-network.org/api
# 后台任务开关 (dev 默认 true, 测试或不需要时设 false)
CLAIM_ENGINE_ENABLED=true
FLIGHT_FETCHER_ENABLED=true
LOG_LEVEL=INFO
