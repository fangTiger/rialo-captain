{
  "framework": "vite",
  "installCommand": "corepack pnpm@9.12.3 install --frozen-lockfile",
  "buildCommand": "node scripts/ensure-production-env.mjs && corepack pnpm@9.12.3 build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
